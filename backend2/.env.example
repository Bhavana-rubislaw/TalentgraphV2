# TalentGraph V2 Environment Variables

# JWT Secret Key
APP_JWT_SECRET=talentgraph-secret-key-v2-2024

# PostgreSQL Database Connection
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talentgraph_v2

# ===================================================================
# SMTP Email Configuration (Dedicated TalentGraph Gmail Account)
# ===================================================================
# Interview emails are sent from a dedicated TalentGraph Gmail account
# to both candidate (To:) and recruiter (CC:), with Reply-To pointing to recruiter
#
# Setup Instructions:
# 1. Create/use dedicated Gmail account: talentgraph.interviews@gmail.com
# 2. Enable 2-Step Verification on the Gmail account
# 3. Generate App Password: https://myaccount.google.com/apppasswords
# 4. Use the 16-character App Password (NOT your regular Gmail password)
# 5. Fill in the values below
#
# NOTE: Never commit real passwords to version control
# ===================================================================

# Gmail SMTP server (default: smtp.gmail.com)
SMTP_HOST=smtp.gmail.com

# Gmail SMTP port (587 for TLS, 465 for SSL)
SMTP_PORT=587

# Dedicated TalentGraph Gmail account username
SMTP_USERNAME=talentgraph.interviews@gmail.com

# Gmail App Password (16 characters from Google App Passwords)
# Get it from: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=uoghblblqynijiym
# From email address (should match SMTP_USERNAME for Gmail)
SMTP_FROM_EMAIL=talentgraph.interviews@gmail.com

# Display name in "From" field
SMTP_FROM_NAME=TalentGraph Interviews

# Use TLS encryption (required for Gmail on port 587)
SMTP_USE_TLS=true

# ===================================================================
# Legacy environment variable support (for backward compatibility)
# If SMTP_* variables are not set, system falls back to MAIL_* variables
# ===================================================================
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=talentgraph.interviews@gmail.com
# MAIL_PASSWORD=your_google_app_password_here
# MAIL_FROM=talentgraph.interviews@gmail.com
# MAIL_FROM_NAME=TalentGraph Interviews

# ═══════════════════════════════════════════════════════════════════════════
# PHASE 3 & 4: PLATFORM EXPANSION
# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# EMAIL SERVICE (Phase 3.2 - Inbound Email Threading)
# ───────────────────────────────────────────────────────────────────────────
EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=SG.your-sendgrid-api-key
SENDGRID_WEBHOOK_SECRET=your-webhook-verification-key
SENDGRID_FROM_EMAIL=noreply@talentgraph.com
SENDGRID_FROM_NAME=TalentGraph

# Reply-to domain for inbound email threading
REPLY_TO_DOMAIN=talentgraph.com
APP_BASE_URL=https://talentgraph.com
FRONTEND_URL=http://localhost:3003

# ───────────────────────────────────────────────────────────────────────────
# WORKERS & SCHEDULER (Phase 4.3 - Automation)
# ───────────────────────────────────────────────────────────────────────────
# Enable/disable background workers
WORKERS_ENABLED=true

# ───────────────────────────────────────────────────────────────────────────
# SECURITY & LIMITS
# ───────────────────────────────────────────────────────────────────────────
# Rate limiting (requests per minute)
RATE_LIMIT_PER_MINUTE=60

# ───────────────────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────────────
FEATURE_EMAIL_THREADING_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_LIFECYCLE_AUTOMATION_ENABLED=true
